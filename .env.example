# ── Apify ─────────────────────────────────────────────────────────────────────
# Required for live ad scraping (top 50 ads by impression via Facebook Ads Library).
# Without this key the app automatically falls back to demo/mock data.
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Optional: override the default actor (curious_coder/facebook-ads-library-scraper)
APIFY_ACTOR_ID=

# ── AI Analysis ───────────────────────────────────────────────────────────────
# Required for AI-powered creative copy summarisation (Gemini Flash).
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Reserved for future Anthropic model support.
ANTHROPIC_API_KEY=

# ── Feature flags ─────────────────────────────────────────────────────────────
# Force mock data regardless of API key presence.
# The app falls back to demo mode automatically when APIFY_API_TOKEN is absent.
NEXT_PUBLIC_DEMO_MODE=false
